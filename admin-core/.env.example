# ===========================================
# ADMIN-CORE ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your actual values.
#
# Required variables are marked with (REQUIRED).
# Variables with default suggestions are optional.

# ===========================================
# DATABASE (REQUIRED)
# ===========================================
# Using Turso (LibSQL) as the database backend.
# Get your credentials from: https://turso.tech

# Database connection URL (Production Turso database)
TURSO_DATABASE_URL=libsql://your-db-name-abc123.turso.io
# or for local development:
# DATABASE_URL=file:local.db

# Database authentication token
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ===========================================
# AUTHENTICATION (REQUIRED)
# ===========================================

# Secret key for session signing (generate a random 32-char string)
# On Unix: openssl rand -hex 16
# On Windows: See SETUP.md for instructions
AUTH_SECRET=your-secure-random-secret-key-here

# ===========================================
# STRIPE PAYMENTS (REQUIRED for quote/payment features)
# ===========================================
# Get keys from: https://dashboard.stripe.com

# Stripe secret key (starts with sk_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe publishable key (starts with pk_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe API version (optional, defaults to 2024-11-20.acacia)
STRIPE_API_VERSION=2024-11-20.acacia

# Stripe webhook secret (for webhook verification)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===========================================
# EMAIL / SMTP (REQUIRED for sending quotes/notifications)
# ===========================================

# SMTP server hostname
SMTP_HOST=smtp.gmail.com
# SMTP_HOST=smtp.sendgrid.net
# SMTP_HOST=smtp.mailgun.org

# SMTP port (typically 587 for TLS or 465 for SSL)
SMTP_PORT=587

# SMTP username/email
SMTP_USER=your-email@gmail.com

# SMTP password or app password
SMTP_PASS=your-app-password-here

# Email address to send from
FROM_EMAIL=noreply@yourcompany.com

# Display name for emails (optional)
FROM_NAME=Your Company Name

# ===========================================
# AWS S3 / CLOUDFLARE R2 STORAGE (REQUIRED for file uploads)
# ===========================================
# For AWS S3: https://aws.amazon.com/s3/
# For Cloudflare R2 (cheaper): https://www.cloudflare.com/products/r2/

# AWS Access Key ID
AWS_ACCESS_KEY_ID=your_access_key_id

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# S3 bucket name
AWS_S3_BUCKET=your-bucket-name

# AWS region (default: us-east-1)
AWS_REGION=us-east-1

# For Cloudflare R2 (alternative to AWS S3):
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_BUCKET_NAME=your-bucket-name

# ===========================================
# BUSINESS CONFIGURATION (OPTIONAL)
# ===========================================
# These can be set here or configured in the admin panel.

# Business name (default: "Mountain Springs Cleaning")
BUSINESS_NAME=Mountain Springs Cleaning

# Business email (default: "bookings@mountainspringsclean.com")
BUSINESS_EMAIL=bookings@mountainspringsclean.com

# Business phone (default: "+1 (702) 555-CLEAN")
BUSINESS_PHONE=+1 (702) 555-CLEAN

# Website URL (default: "https://mountainspringsclean.com")
WEBSITE_URL=https://mountainspringsclean.com

# Timezone (default: "America/Los_Angeles")
TIMEZONE=America/Los_Angeles

# ===========================================
# NEXT.JS ENVIRONMENT (OPTIONAL)
# ===========================================

# Environment (development, preview, production)
# NEXT_PUBLIC_ENVIRONMENT=production

# Vercel environment
# VERCEL_ENV=production
# VERCEL_URL=your-domain.com

# ===========================================
# OPTIONAL: ANALYTICS & MONITORING
# ===========================================

# Vercel Analytics token (optional)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Sentry error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=

# ===========================================
# OPTIONAL: DEVELOPMENT SETTINGS
# ===========================================

# Debug mode (set to "true" for verbose logging)
# DEBUG=false

# Test mode (allows role switching without logging out)
# ENABLE_TEST_MODE=false
